---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getPath } from "@/utils/getPath";
import getSortedPosts from "@/utils/getSortedPosts";
import portrait from "@/assets/portrait.png";

const allPosts = await getCollection("blog");
const recentPosts = getSortedPosts(allPosts).slice(0, 3);

const formatMonthYear = (d: Date) => {
  const mm = String(d.getMonth() + 1).padStart(2, "0");
  return `${mm} / ${d.getFullYear()}`;
};

---

<Layout>
  <Header />
  <main id="main-content" class="app-layout flex flex-1 flex-col">
    <section class="mt-12 sm:mt-16">
      <div
        class="flex flex-col items-start gap-3 sm:flex-row sm:items-start sm:gap-7"
      >
        <Image
          src={portrait}
          alt="Portrait of James Mensch"
          width={240}
          height={240}
          loading="eager"
          class="h-[104px] w-[104px] shrink-0 rounded-[4px] object-cover sm:h-[120px] sm:w-[120px]"
          style="filter: contrast(0.95) saturate(0.85) sepia(0.08);"
        />
        <div class="flex flex-col">
          <h1
            class="font-serif text-[1.65rem] leading-[1.18] font-bold tracking-[-0.01em] text-foreground sm:text-[2.05rem] sm:tracking-[-0.015em]"
          >
            James Mensch
          </h1>
          <p
            class="mt-3 font-mono text-[0.72rem] tracking-[0.08em] text-foreground-muted uppercase"
          >
            Austin
          </p>
        </div>
      </div>

      <p class="mt-5 font-serif text-[1.18rem] leading-[1.55] text-foreground">
        I build developer tools and the kind of infrastructure most people don't
        notice when it's working. Most of my writing is about Claude Code, agent
        workflows, and a homelab running on a small NUC. I'm based in Austin
        with three dogs.
      </p>
    </section>

    <section class="mt-14">
      <h2
        class="font-mono text-[0.72rem] tracking-[0.08em] text-foreground-muted uppercase"
      >
        Writing
      </h2>
      {
        recentPosts.length === 0 ? (
          <p class="mt-4 text-foreground-muted italic">
            Nothing published yet.
          </p>
        ) : (
          <>
            <ul class="mt-4 flex flex-col gap-3 sm:gap-2">
              {recentPosts.map(post => (
                <li class="flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:gap-4">
                  <span class="font-mono text-[0.72rem] tracking-[0.04em] whitespace-nowrap text-foreground-faint sm:w-[5.5rem] sm:shrink-0">
                    {formatMonthYear(post.data.pubDatetime)}
                  </span>
                  <a
                    href={getPath(post.id, post.filePath)}
                    class="font-serif text-foreground decoration-[1.5px] underline-offset-[3px] hover:text-accent hover:underline"
                  >
                    {post.data.title}
                  </a>
                </li>
              ))}
            </ul>
            <p class="mt-5 text-[0.95rem] text-foreground-muted">
              More at{" "}
              <a
                href="/writing"
                class="text-foreground hover:text-accent hover:underline"
              >
                /writing
              </a>{" "}
              →
            </p>
          </>
        )
      }
    </section>

  </main>
  <Footer />
</Layout>
