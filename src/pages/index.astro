---
import Layout from "@/layouts/Layout.astro";
import IconMail from "@/assets/icons/IconMail.svg";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconLinkedin from "@/assets/icons/IconLinkedin.svg";
import IconBrandX from "@/assets/icons/IconBrandX.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";

const contacts = [
  {
    href: "mailto:james@jamesmensch.com",
    label: "Email",
    Icon: IconMail,
  },
  {
    href: "https://github.com/thebestmensch",
    label: "GitHub",
    Icon: IconGitHub,
  },
  {
    href: "https://www.linkedin.com/in/jamesmensch/",
    label: "LinkedIn",
    Icon: IconLinkedin,
  },
  {
    href: "https://x.com/thebestmensch",
    label: "X",
    Icon: IconBrandX,
  },
] as const;
---

<Layout>
  <main
    id="main-content"
    class="app-layout flex flex-1 flex-col items-center justify-center py-16 sm:py-24"
  >
    <section class="w-full max-w-xl text-center">
      <h1 class="mb-4 text-4xl font-bold tracking-tight sm:text-5xl">
        James Mensch
      </h1>
      <p class="mb-10 text-lg text-foreground-muted sm:text-xl">
        Building products that make the world a better place.
      </p>

      <a
        href="/writing"
        class="group mb-12 inline-flex min-h-[44px] items-center gap-2 rounded-lg bg-accent px-6 py-3 text-base font-semibold text-background transition-colors hover:bg-accent-hover focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        <span>Writing</span>
        <IconArrowRight
          class="size-5 transition-transform group-hover:translate-x-0.5 rtl:-rotate-180"
        />
      </a>

      <ul
        class="grid grid-cols-2 place-items-center gap-x-2 gap-y-1 text-foreground-muted sm:flex sm:flex-row sm:flex-nowrap sm:gap-x-1"
      >
        {
          contacts.map(({ href, label, Icon }) => (
            <li>
              <a
                href={href}
                class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center gap-2 rounded-md px-3 py-2 hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                target={href.startsWith("http") ? "_blank" : undefined}
                rel={
                  href.startsWith("http") ? "noopener noreferrer" : undefined
                }
              >
                <Icon aria-hidden="true" class="size-5" />
                <span class="text-sm">{label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>
