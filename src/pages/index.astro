---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import getSortedPosts from "@/utils/getSortedPosts";
import { formatMonthYear } from "@/utils/formatMonthYear";
import portrait from "@/assets/portrait.png";
import couple from "@/assets/couple.png";
import bean from "@/assets/dogs/bean.png";
import gia from "@/assets/dogs/gia.png";
import ruthie from "@/assets/dogs/ruthie.png";

const allPosts = await getCollection("blog");
const recentPosts = getSortedPosts(allPosts).slice(0, 3);
---

<Layout>
  <Header />
  <main id="main-content" class="app-layout flex flex-1 flex-col">
    <section class="bio-section mt-12 sm:mt-16">
      <div
        class="flex flex-col items-start gap-4 sm:flex-row sm:items-end sm:gap-8"
      >
        <Image
          src={portrait}
          alt="Portrait of James Mensch"
          width={400}
          height={400}
          loading="eager"
          class="h-[160px] w-[160px] shrink-0 rounded-[4px] object-cover sm:h-[200px] sm:w-[200px]"
          style="filter: contrast(0.95) saturate(0.85) sepia(0.08);"
        />
        <div class="flex flex-col">
          <h1
            class="font-serif text-[1.65rem] leading-[1.18] font-bold tracking-[-0.01em] text-foreground sm:text-[2rem] sm:tracking-[-0.015em]"
          >
            James Mensch
          </h1>
          <p
            class="mt-2 font-mono text-[0.7rem] tracking-[0.08em] text-foreground-muted uppercase"
          >
            Founder · Engineer
          </p>
        </div>
      </div>

      <div class="bio-prose relative mt-6">
        <p class="font-serif text-[1.08rem] leading-[1.6] text-foreground">
          <span class="bio-chunk"
            >I build for the human side of tech. Cofounder and CTO at OneOnMe, a
            kinder way to send gifts in an increasingly virtualized world.
            Before that, cofounded Magnifai for public-agency data work and led
            product and frontend at New Knowledge, fighting disinformation.
            Engineer at Google in between. At home in Austin with my
          </span><span class="dogs-trigger cursor-default"
            >partner and three dogs</span
          ><span class="bio-chunk">.</span>
        </p>
        <div class="pack-pop" aria-hidden="true">
          <figure class="pack-cell pack-cell--couple">
            <Image
              src={couple}
              alt=""
              width={256}
              height={256}
              class="pack-img"
            />
          </figure>
          <figure class="pack-cell">
            <Image
              src={bean}
              alt=""
              width={192}
              height={208}
              class="pack-img"
            />
            <figcaption>Bean</figcaption>
          </figure>
          <figure class="pack-cell pack-cell--lg">
            <Image src={gia} alt="" width={192} height={208} class="pack-img" />
            <figcaption>Gia</figcaption>
          </figure>
          <figure class="pack-cell">
            <Image
              src={ruthie}
              alt=""
              width={192}
              height={208}
              class="pack-img"
            />
            <figcaption>Ruthie</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="mt-14">
      <h2
        class="font-mono text-[0.72rem] tracking-[0.08em] text-foreground-muted uppercase"
      >
        Writing
      </h2>
      {
        recentPosts.length === 0 ? (
          <p class="mt-4 text-foreground-muted italic">
            Nothing published yet.
          </p>
        ) : (
          <>
            <ul class="mt-4 flex flex-col gap-5">
              {recentPosts.map(post => (
                <li class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-4">
                  <span class="font-mono text-[0.68rem] tracking-[0.04em] whitespace-nowrap text-foreground-faint sm:w-[5.5rem] sm:shrink-0">
                    {formatMonthYear(
                      post.data.modDatetime ?? post.data.pubDatetime,
                      post.data.timezone
                    )}
                  </span>
                  <div class="flex flex-col gap-1.5">
                    <a
                      href={getPath(post.id, post.filePath)}
                      class="font-serif text-foreground decoration-[1.5px] underline-offset-[3px] hover:text-accent hover:underline"
                    >
                      {post.data.title}
                    </a>
                    {post.data.description && (
                      <p class="text-[0.88rem] leading-[1.5] text-foreground-muted">
                        {post.data.description}
                      </p>
                    )}
                    {post.data.tags && post.data.tags.length > 0 && (
                      <ul class="mt-0.5 flex flex-wrap gap-x-3 gap-y-1 font-mono text-[0.7rem] text-foreground-faint">
                        {post.data.tags.map(tag => (
                          <li>
                            <a
                              href={`/writing/tags/${slugifyStr(tag)}`}
                              class="hover:text-accent"
                            >
                              #{tag}
                            </a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </li>
              ))}
            </ul>
            <p class="mt-6 text-[0.88rem] text-foreground-muted">
              <a
                href="/writing"
                class="text-foreground hover:text-accent hover:underline"
              >
                More →
              </a>
            </p>
          </>
        )
      }
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .dogs-trigger {
    border-bottom: 1px dotted rgba(127, 127, 127, 0.55);
    position: relative;
    z-index: 1;
  }

  .bio-chunk {
    transition:
      filter 240ms ease-out,
      opacity 240ms ease-out;
  }

  .bio-section:has(.dogs-trigger:hover) .bio-chunk,
  .bio-section:has(.dogs-trigger:focus-visible) .bio-chunk {
    filter: blur(2.5px);
    opacity: 0.55;
  }

  .pack-pop {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 1.4rem;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 6px;
    pointer-events: none;
    z-index: 3;
  }

  .pack-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 0;
    margin: 0;
    opacity: 0;
    transform: translateY(18px) scale(0.85);
    transform-origin: bottom center;
    transition:
      opacity 280ms ease-out,
      transform 380ms cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: 0ms;
  }

  .pack-cell:nth-child(2) {
    transition-delay: 80ms;
    margin-right: -40px;
  }
  .pack-cell:nth-child(3) {
    transition-delay: 160ms;
  }
  .pack-cell:nth-child(4) {
    transition-delay: 240ms;
    margin-left: -25px;
  }

  .pack-img {
    display: block;
    width: auto;
    height: 90px;
    object-fit: contain;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.22));
  }

  .pack-cell--lg .pack-img {
    height: 135px;
  }

  .pack-cell--lg figcaption {
    transform: translateY(-10px);
  }

  .pack-cell:nth-child(2) figcaption {
    transform: translateX(6px);
  }

  .pack-cell--couple .pack-img {
    height: 110px;
    border-radius: 6px;
  }

  @media (min-width: 640px) {
    .pack-img {
      height: 100px;
    }
    .pack-cell--lg .pack-img {
      height: 150px;
    }
    .pack-cell--couple .pack-img {
      height: 120px;
    }
  }

  @media (max-width: 639px) {
    .pack-pop {
      display: none;
    }
    .dogs-trigger {
      border-bottom: none;
      cursor: default;
    }
  }

  .pack-cell figcaption {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    color: var(--color-foreground-muted, currentColor);
    text-transform: uppercase;
    margin-top: -6px;
  }

  .bio-section:has(.dogs-trigger:hover) .pack-cell,
  .bio-section:has(.dogs-trigger:focus-visible) .pack-cell {
    opacity: 1;
  }

  .bio-section:has(.dogs-trigger:hover) .pack-cell:nth-child(1),
  .bio-section:has(.dogs-trigger:focus-visible) .pack-cell:nth-child(1) {
    transform: translateY(2px) rotate(-7deg) scale(1);
  }

  .bio-section:has(.dogs-trigger:hover) .pack-cell:nth-child(2),
  .bio-section:has(.dogs-trigger:focus-visible) .pack-cell:nth-child(2) {
    transform: translateY(-4px) rotate(-13deg) scale(1);
  }

  .bio-section:has(.dogs-trigger:hover) .pack-cell:nth-child(3),
  .bio-section:has(.dogs-trigger:focus-visible) .pack-cell:nth-child(3) {
    transform: translateY(1px) rotate(5deg) scale(1);
  }

  .bio-section:has(.dogs-trigger:hover) .pack-cell:nth-child(4),
  .bio-section:has(.dogs-trigger:focus-visible) .pack-cell:nth-child(4) {
    transform: translateY(-8px) rotate(11deg) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .bio-chunk,
    .pack-cell {
      transition:
        opacity 200ms ease-out,
        filter 200ms ease-out;
      transform: none;
    }
    .bio-section:has(.dogs-trigger:hover) .pack-cell,
    .bio-section:has(.dogs-trigger:focus-visible) .pack-cell,
    .bio-section:has(.dogs-trigger:hover) .pack-cell:nth-child(1),
    .bio-section:has(.dogs-trigger:hover) .pack-cell:nth-child(2),
    .bio-section:has(.dogs-trigger:hover) .pack-cell:nth-child(3),
    .bio-section:has(.dogs-trigger:hover) .pack-cell:nth-child(4),
    .bio-section:has(.dogs-trigger:focus-visible) .pack-cell:nth-child(1),
    .bio-section:has(.dogs-trigger:focus-visible) .pack-cell:nth-child(2),
    .bio-section:has(.dogs-trigger:focus-visible) .pack-cell:nth-child(3),
    .bio-section:has(.dogs-trigger:focus-visible) .pack-cell:nth-child(4) {
      transform: none;
      transition-delay: 0ms;
    }
  }
</style>
