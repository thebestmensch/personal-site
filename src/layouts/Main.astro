---
import Breadcrumb from "@/components/Breadcrumb.astro";

type StringTitle = { pageTitle: string };
type ArrayTitle = { pageTitle: [string, string]; titleTransition: string };

type Props = (StringTitle | ArrayTitle) & { pageDesc?: string };

const { props } = Astro;
---

<Breadcrumb />
<main id="main-content" class="app-layout pb-4">
  {
    "titleTransition" in props ? (
      <h1 class="font-serif text-[1.75rem] leading-[1.18] font-bold tracking-[-0.01em] text-foreground sm:text-[2.1rem] sm:tracking-[-0.015em]">
        {props.pageTitle[0]}
        <span transition:name={props.titleTransition}>
          {props.pageTitle[1]}
        </span>
      </h1>
    ) : (
      <h1 class="font-serif text-[1.75rem] leading-[1.18] font-bold tracking-[-0.01em] text-foreground sm:text-[2.1rem] sm:tracking-[-0.015em]">
        {props.pageTitle}
      </h1>
    )
  }
  {
    props.pageDesc && (
      <p class="mt-3 mb-8 font-serif text-[1rem] leading-[1.55] text-foreground-muted italic">
        {props.pageDesc}
      </p>
    )
  }
  <slot />
</main>
